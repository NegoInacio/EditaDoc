{
  "name": "@editadoc/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/services/ai/prompts dist/services/ai/prompts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "assets:generate": "tsx src/services/assets/generate_base_template.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "bcrypt": "^5.1.1",
    "docx": "^8.5.0",
    "docxtemplater": "^3.49.0",
    "drizzle-orm": "^0.31.0",
    "fastify": "^4.28.0",
    "jsonwebtoken": "^9.0.2",
    "pdfjs-dist": "^4.4.168",
    "pg": "^8.12.0",
    "pino": "^9.3.1",
    "pizzip": "^3.1.7",
    "puppeteer": "^22.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
